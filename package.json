{
  "name": "claude-lab",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "A desktop app that orchestrates Claude Code agents as a configurable hierarchy, shown as an interactive node graph.",
  "main": "electron/main.cjs",
  "scripts": {
    "spike": "tsx src/spike.ts",
    "spike:dry": "tsx src/spike.ts --dry",
    "bridge": "tsx server/bridge.mjs",
    "build:ui": "npm --prefix ui run build",
    "build:server": "node scripts/build-server.mjs",
    "desktop": "npm run build:ui && npm run build:server && electron electron/main.cjs",
    "desktop:dev": "LAB_DEV=1 concurrently -k -n vite,electron \"npm --prefix ui run dev\" \"electron electron/main.cjs\"",
    "dist:mac": "npm run build:ui && npm run build:server && electron-builder --mac"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.178",
    "@anthropic-ai/sdk": "^0.104.2",
    "express": "^4.21.0",
    "zod": "^4.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "0.3.178"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.claudelab.app",
    "productName": "Claude Lab",
    "asar": false,
    "files": ["electron/**", "dist-server/**", "ui/dist/**"],
    "extraResources": [{ "from": "data-seed", "to": "data-seed", "filter": ["labs.json", "graph*.json"] }],
    "mac": { "target": "dmg", "category": "public.app-category.developer-tools", "icon": "build/icon.icns" },
    "directories": { "output": "release" }
  }
}
